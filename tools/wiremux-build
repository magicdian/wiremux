#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path


def main() -> int:
    script_path = Path(__file__).resolve()
    repo_root = script_path.parent.parent
    helper_dir = repo_root / "tools" / "wiremux-build-helper"
    manifest_path = helper_dir / "Cargo.toml"

    if not manifest_path.exists():
        print(f"error: missing helper manifest: {manifest_path}", file=sys.stderr)
        return 2

    cmd = [
        "cargo",
        "run",
        "--quiet",
        "--manifest-path",
        str(manifest_path),
        "--",
        *sys.argv[1:],
    ]
    print("+ " + " ".join(cmd), file=sys.stderr, flush=True)
    completed = subprocess.run(cmd, cwd=repo_root, env=os.environ.copy())
    return completed.returncode


if __name__ == "__main__":
    raise SystemExit(main())
